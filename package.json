    "chai": "6.2.2",
    "chai-as-promised": "8.0.2",
    "eslint": "7.32.0",
    "eslint-plugin-ghost": "2.5.0",
    "has-ansi": "4.0.1",
    "mocha": "11.7.5",
    "nock": "14.0.12",
    "nyc": "18.0.0",
    "proxyquire": "2.1.3",
    "sinon": "21.1.2",
