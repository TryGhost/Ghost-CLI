{
  "extends": [
    "github>tryghost/renovate-config",
    ":semanticCommitTypeAll(chore)"
  ],
  "ignoreDeps": [
    "cli-table3",
    "standard-version",
    "validator"
  ],
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "groupName": "CLI Tools",
      "matchPackageNames": ["chalk", "inquirer", "listr", "log-symbols", "ora"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "groupName": "Well Known",
      "matchPackageNames": ["debug", "fs-extra", "got", "lodash", "moment", "semver", "yarn"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
